# comparaU.com — copia a .env y completa. NUNCA subas .env al repo.
# Base de datos
POSTGRES_USER=comparau
POSTGRES_PASSWORD=cambia_esta_clave_segura
POSTGRES_DB=comparau
DATABASE_URL=postgresql+psycopg://comparau:cambia_esta_clave_segura@db:5432/comparau

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_WORKERS=3
ENV=production
API_KEYS=clave_demo_publica_1,clave_demo_publica_2
CORS_ORIGINS=https://comparau.com,https://www.comparau.com

# Rate limiting
RATE_LIMIT=1000/hour
